#!/usr/bin/env bash
# Usage: smart-split [-- command args...]
set -euo pipefail

pane_id="${WEZTERM_PANE:?WEZTERM_PANE is not set (run inside WezTerm)}"

dims=$(wezterm cli list --format json | jq -r \
  --argjson id "$pane_id" \
  '.[] | select(.pane_id == $id) | "\(.size.cols) \(.size.rows)"')

cols=${dims%% *}
rows=${dims##* }

# cols/2: a terminal cell renders ~2x taller than wide
if (( cols / 2 > rows )); then
  wezterm cli split-pane --pane-id "$pane_id" --right "$@"
else
  wezterm cli split-pane --pane-id "$pane_id" --bottom "$@"
fi
