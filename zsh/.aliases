# fzf — f* series
# ff: find file (Ctrl+E to open in editor)
ff() {
  local out key file
  out=$(fzf \
    --height=100% --layout=reverse --border \
    --border-label " C-e:edit | C-y:copy | C-o:cd | C-p:preview " \
    --preview "bat --color=always --style=numbers --line-range=:500 {}" \
    --preview-window=right:50%:wrap \
    --bind "ctrl-f:half-page-down,ctrl-b:half-page-up" \
    --bind "ctrl-d:preview-half-page-down,ctrl-u:preview-half-page-up" \
    --bind "ctrl-p:toggle-preview" \
    --bind "ctrl-y:execute-silent(echo -n {} | _dotfiles_copy)+abort" \
    --expect=ctrl-e,ctrl-o \
    < <(fd --type f --hidden --exclude .git))
  key=$(echo "$out" | head -1)
  file=$(echo "$out" | tail -1)
  [ -z "$file" ] && return
  case "$key" in
    ctrl-e) $EDITOR "$file" ;;
    ctrl-o) cd "$(dirname "$file")" ;;
    *) echo "$file" ;;
  esac
}

# f/: live grep (rg + fzf + bat)
f/() {
  local RG_CMD="rg --color=always --smart-case --line-number --no-heading"
  local out key selection file line
  out=$(fzf --disabled --ansi --multi --delimiter=: \
    --height=100% --layout=reverse --border \
    --border-label " C-e:edit | C-y:copy | C-p:preview | live grep " \
    --bind "start:reload:$RG_CMD -- {q} || :" \
    --bind "change:reload:sleep 0.1; $RG_CMD -- {q} || :" \
    --preview 'f={1}; l={2}; f=${f//\x1b\[[0-9;]*m/}; l=${l//\x1b\[[0-9;]*m/}; bat --color=always --style=numbers --highlight-line "$l" --line-range=$(( l-10 > 0 ? l-10 : 1 )):$(( l+20 )) "$f"' \
    --preview-window=right:50%:wrap \
    --bind "ctrl-f:half-page-down,ctrl-b:half-page-up" \
    --bind "ctrl-d:preview-half-page-down,ctrl-u:preview-half-page-up" \
    --bind "ctrl-p:toggle-preview" \
    --bind "ctrl-y:execute-silent(echo -n {1} | _dotfiles_copy)+abort" \
    --expect=ctrl-e \
    --query "$*")
  key=$(echo "$out" | head -1)
  selection=$(echo "$out" | sed -n '2p')
  [ -z "$selection" ] && return
  file=$(echo "$selection" | cut -d: -f1)
  line=$(echo "$selection" | cut -d: -f2)
  case "$key" in
    ctrl-e) $EDITOR "$file" +"$line" ;;
    *) echo "$selection" ;;
  esac
}

# fz: fuzzy zoxide directory jump
fz() {
  local dir
  dir=$(fzf \
    --height=100% --layout=reverse --border \
    --border-label " enter:cd | C-y:copy | C-p:preview " \
    --nth 2.. --no-sort --query "$*" \
    --preview "eza --icons --tree --level=2 --color=always {2..}" \
    --preview-window=right:50%:wrap \
    --bind "ctrl-f:half-page-down,ctrl-b:half-page-up" \
    --bind "ctrl-d:preview-half-page-down,ctrl-u:preview-half-page-up" \
    --bind "ctrl-p:toggle-preview" \
    --bind "ctrl-y:execute-silent(echo -n {2..} | _dotfiles_copy)+abort" \
    --bind 'enter:become:echo {2..}' \
    < <(zoxide query --list --score))
  [ -n "$dir" ] && cd "$dir"
}


# fh: fuzzy history (atuin). In wezterm, opens a side pane with stats.
fh() {
  local wez
  case "$OSTYPE" in
    darwin*)  command -v wezterm >/dev/null 2>&1 && wez=wezterm ;;
    linux-gnu*) command -v wezterm.exe >/dev/null 2>&1 && wez=wezterm.exe ;;
  esac

  if [ -n "$wez" ] && [ "$TERM_PROGRAM" = "WezTerm" ]; then
    local stats_pane current_pane
    current_pane=${WEZTERM_PANE:-$($wez cli list --format json 2>/dev/null | jq -r '.[] | select(.is_active) | .pane_id')}
    local stats_cmd='ATUIN_SESSION= atuin stats; printf "\e[?25l"; cat > /dev/null'
    stats_pane=$($wez cli split-pane --right --percent 30 -- bash -c "PATH='$PATH' $stats_cmd")
    $wez cli activate-pane --pane-id "$current_pane" 2>/dev/null
    $wez cli activate-pane --pane-id "$current_pane" 2>/dev/null
    atuin search -i "$@"
    $wez cli kill-pane --pane-id "$stats_pane" 2>/dev/null
    return
  fi

  atuin search -i "$@"
}

# legacy
alias edot='nvim $(fd --type f . ~/.config/.dotfiles | fzf --preview "bat --color=always {}")'
# fa: find alias/function and execute
fa() {
  local out key cmd
  out=$(fzf \
    --height=100% --layout=reverse --border \
    --border-label " enter:execute | C-y:copy | C-e:edit | C-p:preview " \
    --preview 'grep -n -A10 "$(echo {} | cut -d= -f1 | sed "s/ (function)//;s/^ *//;s/ *$//")" ~/.config/zsh/.aliases | bat --color=always -l zsh --style=numbers' \
    --preview-window=right:50%:wrap \
    --bind "ctrl-f:half-page-down,ctrl-b:half-page-up" \
    --bind "ctrl-d:preview-half-page-down,ctrl-u:preview-half-page-up" \
    --bind "ctrl-p:toggle-preview" \
    --bind "ctrl-y:execute-silent(echo -n {} | _dotfiles_copy)+abort" \
    --expect=ctrl-e \
    < <({ grep -E '^alias ' "$XDG_CONFIG_HOME/zsh/.aliases" | sed 's/^alias //'; grep -E '^[a-z].*\(\)' "$XDG_CONFIG_HOME/zsh/.aliases" | sed 's/() {.*/ (function)/' }))
  key=$(echo "$out" | head -1)
  cmd=$(echo "$out" | tail -1 | cut -d'=' -f1 | sed 's/ (function)//')
  [ -z "$cmd" ] && return
  case "$key" in
    ctrl-e) $EDITOR "$XDG_CONFIG_HOME/zsh/.aliases" ;;
    *) print -z "$cmd" ;;
  esac
}

# yazi
function y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
	command yazi "$@" --cwd-file="$tmp"
	IFS= read -r -d '' cwd < "$tmp"
	[ "$cwd" != "$PWD" ] && [ -d "$cwd" ] && builtin cd -- "$cwd"
	rm -f -- "$tmp"
}

# todo
alias todo="$EDITOR $XDG_DATA_HOME/todo/todo.md"

# gdu — binary name differs by platform
if command -v gdu-go >/dev/null 2>&1; then
  alias disk="gdu-go"
elif command -v gdu >/dev/null 2>&1; then
  alias disk="gdu"
fi

# find port num
alias portall="sudo lsof -nP | grep LISTEN"

# port: find process using a specific port
port() {
  sudo lsof -nP -i4TCP:$1 | grep LISTEN
}

# ping: gping (graph) when 1 arg, tcping when host+port
ping_or_tcping() {
  if [ "$#" -lt 1 ]; then
    echo "Usage: ping <IP address> [Port]"
    return 1
  fi
  if [ "$#" -eq 2 ]; then
    tcping -t 5 "$1" "$2"
  else
    gping "$1"
  fi
}

# tacky-reload / tacky-theme — switch / re-apply the active tacky-borders
# theme. Config lives in the dotfiles repo itself (tacky-borders/config.yaml,
# gitignored) since %USERPROFILE%\.config\tacky-borders is an NTFS symlink
# to this dir. Watcher on the UNC-backed symlink is dead (9P doesn't deliver
# ReadDirectoryChangesW events), so reload requires a process restart —
# delegated to the 'tacky-borders' Scheduled Task so restart happens at
# RunLevel=Highest. WSL-only.
#
# tacky-reload   : re-apply the currently-active theme
# tacky-theme    : list themes, marking the currently-applied one with *
# tacky-theme X  : switch to theme X
if [[ -n "${WSL_DISTRO_NAME:-}" ]] && command -v wslpath >/dev/null 2>&1; then
  _tacky_live_config() {
    printf '%s/.dotfiles/tacky-borders/config.yaml' "$XDG_CONFIG_HOME"
  }
  _tacky_current_theme() {
    local dst; dst="$(_tacky_live_config)"
    [[ -f "$dst" ]] && grep -oE '^# Theme:[[:space:]]*[A-Za-z0-9_-]+' "$dst" | head -1 | awk '{print $3}'
  }
  _tacky_restart() {
    powershell.exe -NoProfile -Command "Start-ScheduledTask -TaskName 'tacky-borders' -ErrorAction SilentlyContinue" >/dev/null 2>&1
  }
  tacky-reload() {
    local cur; cur="$(_tacky_current_theme)"
    if [[ -z "$cur" ]]; then
      printf 'tacky-reload: could not detect current theme; run `tacky-theme <name>`\n' >&2
      return 1
    fi
    tacky-theme "$cur"
  }
  tacky-theme() {
    local themes_dir dst cur src f name marker
    themes_dir="$XDG_CONFIG_HOME/.dotfiles/tacky-borders/themes"
    dst="$(_tacky_live_config)"
    if [[ $# -eq 0 ]]; then
      cur="$(_tacky_current_theme)"
      printf 'tacky-borders themes:\n'
      for f in "$themes_dir"/*.yaml; do
        name="$(basename "$f" .yaml)"
        marker=' '
        [[ "$name" == "$cur" ]] && marker='*'
        printf '  %s %s\n' "$marker" "$name"
      done
      return 0
    fi
    src="$themes_dir/$1.yaml"
    if [[ ! -f "$src" ]]; then
      printf 'tacky-theme: no such theme %q\n' "$1" >&2
      printf 'available: %s\n' "$(ls "$themes_dir" 2>/dev/null | sed 's/\.yaml$//' | paste -sd, -)" >&2
      return 1
    fi
    cp "$src" "$dst" && _tacky_restart && printf 'tacky-borders: switched to %s\n' "$1"
  }
  # Automatic daily theme rotation driven by a Scheduled Task (AtLogOn +
  # Daily 00:05). `tacky-rotate` (no args) = now.
  #   now     apply today's deterministic pick immediately
  #   on      enable the scheduled task
  #   off     disable the scheduled task (theme stays whatever's active)
  #   status  show task state + today's pick + next run
  tacky-rotate() {
    local cmd script_path
    cmd="${1:-now}"
    script_path="$(wslpath -w "$XDG_CONFIG_HOME/.dotfiles/tacky-borders/rotate.ps1")"
    case "$cmd" in
      now)
        powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$script_path" 2>&1 | tr -d '\r'
        ;;
      on)
        powershell.exe -NoProfile -Command "Enable-ScheduledTask -TaskName 'tacky-rotate' | Out-Null" \
          && echo 'tacky-rotate: auto-rotation ENABLED'
        ;;
      off)
        powershell.exe -NoProfile -Command "Disable-ScheduledTask -TaskName 'tacky-rotate' | Out-Null" \
          && echo 'tacky-rotate: auto-rotation DISABLED'
        ;;
      status)
        powershell.exe -NoProfile -Command "
          \$t = Get-ScheduledTask -TaskName 'tacky-rotate' -ErrorAction SilentlyContinue
          if (-not \$t) { Write-Output 'tacky-rotate: task not registered'; return }
          \$info = Get-ScheduledTaskInfo -TaskName 'tacky-rotate'
          Write-Output ('state : ' + \$t.State)
          Write-Output ('next  : ' + \$info.NextRunTime)
          Write-Output ('last  : ' + \$info.LastRunTime + ' (result: ' + \$info.LastTaskResult + ')')
        " 2>&1 | tr -d '\r'
        ;;
      *)
        echo 'usage: tacky-rotate [now|on|off|status]' >&2
        return 1
        ;;
    esac
  }
fi

