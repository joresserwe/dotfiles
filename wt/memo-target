#!/bin/sh
# nvim lives on brew paths that a bare `wsl -e sh` PATH does not include.
if [ -z "$MEMO_TARGET_ENV" ]; then
  MEMO_TARGET_ENV=1 exec /usr/bin/zsh -lc "/bin/sh $0 $*"
fi

# The target path arrives via %TEMP%\open-memo-target.txt, not argv:
# wt strips quotes from pass-through command-line tokens and wsl.exe -e
# word-splits them, so a Windows path with spaces cannot survive either hop.
win_temp="$(/mnt/c/Windows/System32/cmd.exe /c 'echo %TEMP%' 2>/dev/null | tr -d '\r')"
tmpfile="$(wslpath -u "$win_temp")/open-memo-target.txt"
[ -f "$tmpfile" ] || exit 1
file="$(wslpath -u "$(tr -d '\r' < "$tmpfile")")"
[ -e "$file" ] || exit 1

sock="${XDG_CACHE_HOME:-$HOME/.cache}/nvim/memo.sock"
max="${1:-0}"
i=0
while [ ! -S "$sock" ] && [ "$i" -lt "$max" ]; do
  sleep 0.1
  i=$((i + 1))
done
[ -S "$sock" ] || exit 1
exec nvim --server "$sock" --remote "$file"
