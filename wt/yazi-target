#!/bin/sh
# The target directory arrives via %TEMP%\open-yazi-target.txt, not argv:
# wt strips quotes from pass-through command-line tokens and wsl.exe -e
# word-splits them, so a Windows path with spaces cannot survive either hop.
win_temp="$(/mnt/c/Windows/System32/cmd.exe /c 'echo %TEMP%' 2>/dev/null | tr -d '\r')"
tmpfile="$(wslpath -u "$win_temp")/open-yazi-target.txt"
[ -f "$tmpfile" ] || exit 1
dir="$(wslpath -u "$(tr -d '\r' < "$tmpfile")")"
cd "$dir" || exit 1
# The wt.exe this session rides in inherits a stripped Windows PATH, so
# appendWindowsPath contributes no system dirs; restore them for interop
# tools resolved by name (cmd.exe, clip.exe, explorer.exe).
PATH="$PATH:/mnt/c/Windows/System32:/mnt/c/Windows"
export PATH
exec /usr/bin/zsh -lic yazi
