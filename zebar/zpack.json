{
  "$schema": "https://github.com/glzr-io/zebar/raw/v3.3.1/resources/zpack-schema.json",
  "name": "mac-bar",
  "version": "0.1.0",
  "description": "Slim macOS-menubar-style top bar for glazewm.",
  "tags": ["topbar"],
  "widgets": [
    {
      "name": "bar",
      "htmlPath": "./bar.html",
      "zOrder": "top_most",
      "shownInTaskbar": false,
      "focused": false,
      "resizable": false,
      "transparent": true,
      "includeFiles": ["*.html", "*.css"],
      "caching": { "defaultDuration": 604800, "rules": [] },
      "privileges": {
        "shellCommands": [
          { "program": "cmd.exe", "argsRegex": ".*ime-state\\.txt.*" }
        ]
      },
      "presets": [
        {
          "name": "default",
          "anchor": "top_left",
          "offsetX": "0px",
          "offsetY": "0px",
          "width": "100%",
          "height": "26px",
          "monitorSelection": { "type": "all" },
          "dockToEdge": { "enabled": true, "edge": "top", "windowMargin": "0px" }
        }
      ]
    }
  ]
}
